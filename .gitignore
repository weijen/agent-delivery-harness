# Customer-confidential material — NEVER commit.
# Raw media, screenshots, and decks often contain customer or partner IP and
# must stay out of tracked paths unless explicitly sanitized and approved.
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.pptx
*.ppt
# Allow our own diagrams / template if we ever check one in deliberately.
!docs/**/template-*.pptx

# Python-generated files (added when code lands)
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Test / type-check / lint caches and coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ephemeral per-issue agent working state (local-persistent, never pushed)
.copilot-tracking/issues/issue-*/
.copilot-tracking/plans/*.md
.copilot-tracking/review-gate/
!.copilot-tracking/issues/.gitkeep
!.copilot-tracking/plans/.gitkeep

# Generated eval scorecards are local artifacts and should not be committed
# (l0 eval spec; produced by scripts/trace-scorecard.sh). Keep the dir present.
tests/evals/scorecards/*
!tests/evals/scorecards/.gitkeep

# Local secrets / config — copy .env.example to .env and fill values
.env
.env.local
.env.*.local

# Terraform — state and real tfvars can carry secrets; the provider cache is
# machine-local. Copy terraform.tfvars.example to terraform.tfvars and fill
# values locally. NOTE: .terraform.lock.hcl is deliberately NOT ignored — it
# is committed for reproducible provider pins.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
# Local backend config (real subscription/storage ids) and plan files (plans
# can embed sensitive values) — never committable under any conventional name.
# No bare *.hcl glob here: .terraform.lock.hcl must stay committed.
backend.hcl
*.backend.hcl
tfplan
*.tfplan
# Local-only override overlays.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local SQLite caches / sample data
*.db
*.db-shm
*.db-wal
data/synthetic/
data/raw-video/

# azd / Azure environment (subscription/tenant/object ids — never commit)
.azure/

# OS junk
.DS_Store
Thumbs.db

logs/