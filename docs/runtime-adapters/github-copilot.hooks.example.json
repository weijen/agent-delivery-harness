{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "command": "bash scripts/copilot-trace-hook.sh"
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "command": "bash scripts/copilot-trace-hook.sh"
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "command": "bash scripts/copilot-trace-hook.sh"
      }
    ],
    "subagentStart": [
      {
        "type": "command",
        "command": "bash scripts/copilot-trace-hook.sh"
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "command": "bash scripts/copilot-trace-hook.sh"
      }
    ]
  }
}
