# .env.example — local, non-secret template for the agent-delivery-harness.
#
# This is the ONE shared local-config mechanism. Copy it to .env and fill in
# real values. .env is gitignored; this template is committed and must NEVER
# contain a real secret (connection string, key, or password).
#
# Nothing auto-sources this file. Load it explicitly in the shell that will
# start Copilot / run a manual export, so variables are scoped to that shell:
#
#     set -a; source .env; set +a
#
# ---------------------------------------------------------------------------
# GitHub Copilot subagent OTel Path O enrichment (issue #227)
# ---------------------------------------------------------------------------
# Turn on the official Copilot OpenTelemetry file exporter so the trace hook
# can upgrade harness.subagent from "true" to the real subagent name by
# joining the local OTel span file. Both are OPTIONAL — with them unset the
# hook still stamps harness.subagent="true" (best-effort, never drops a span).
#
# COPILOT_OTEL_ENABLED: set to 1 to enable Copilot OpenTelemetry emission.
COPILOT_OTEL_ENABLED=

# COPILOT_OTEL_FILE_EXPORTER_PATH: absolute path to the local JSONL span sink
# the hook reads for Path O enrichment. Keep it under the gitignored
# .copilot-tracking/otel/ dir so spans never get committed, e.g.:
#   COPILOT_OTEL_FILE_EXPORTER_PATH=/absolute/path/to/repo/.copilot-tracking/otel/spans.jsonl
COPILOT_OTEL_FILE_EXPORTER_PATH=

# ---------------------------------------------------------------------------
# Trace export to Application Insights / OTLP (issue #238)
# ---------------------------------------------------------------------------
# Opt-in trace export for `scripts/trace-export.sh` and the best-effort
# closeout export in `scripts/finish-issue.sh`. Everything here is OPTIONAL and
# OFF by default: with these unset, export is a clean exit-0 no-op that ships
# nothing (never required for CI). See
# docs/runtime-adapters/otlp-azure-monitor.md for the full flow.
#
# Never paste the connection string here — this template is committed. Generate
# a local .env with the real value instead (it stays gitignored):
#     ./scripts/gen-export-env.sh
#
# TRACE_EXPORT_OTLP: set to 1 to enable the App Insights Track API ship path.
TRACE_EXPORT_OTLP=

# APPLICATIONINSIGHTS_CONNECTION_STRING: the sensitive App Insights connection
# string (required only for the ship path). Leave EMPTY here; let
# gen-export-env.sh source it from `terraform output -raw connection_string`.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# TRACE_EXPORT_OTLP_HTTP: set to 1 to enable the native OTLP/HTTP+JSON ship
# path instead of the Track API. Needs an OTLP endpoint below. OPTIONAL.
TRACE_EXPORT_OTLP_HTTP=

# OTEL_EXPORTER_OTLP_ENDPOINT / OTEL_EXPORTER_OTLP_HEADERS: local-only OTLP/HTTP
# collector target and headers (comma-separated Key=Value; a secret surface —
# never commit real values). Used only when TRACE_EXPORT_OTLP_HTTP=1. OPTIONAL.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
